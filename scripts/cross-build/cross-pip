# ── SDK / toolchain discovery ──────────────────────────────────────────


def get_sdk_path():
    return subprocess.check_output(
        ["xcrun", "--sdk", "iphoneos", "--show-sdk-path"], text=True
    ).strip()


def get_cc():
    return subprocess.check_output(
        ["xcrun", "--sdk", "iphoneos", "--find", "clang"], text=True
    ).strip()


def get_cxx():
    return subprocess.check_output(
        ["xcrun", "--sdk", "iphoneos", "--find", "clang++"], text=True
