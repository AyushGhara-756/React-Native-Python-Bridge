# ── PyPI API ───────────────────────────────────────────────────────────


def pypi_json(package):
    url = f"https://pypi.org/pypi/{package}/json"
    req = urllib.request.Request(url, headers={"User-Agent": "cross-pip/1.0"})
    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read())


def get_sdist_url(data, version):
    """Find the sdist (.tar.gz or .zip) URL for a given version."""
    for url_info in data.get("urls", []):
        if url_info.get("packagetype") == "sdist" and url_info.get("version") == version:
            return url_info["url"]
    # Fallback: first sdist for that version
    for url_info in data["urls"]:
        if url_info["packagetype"] == "sdist":
            return url_info["url"]
    return None


def get_requires_dist(data, version):
    """Return list of (name, spec) tuples from requires_dist."""
    raw = data["info"].get("requires_dist") or []
    deps = []
    for entry in raw:
        # Filter out extras-based deps like "numpy; extra == 'test'"
        if " extra ==" in entry or "extra ==" in entry:
            continue
        # Strip environment markers after ";"
        entry = entry.split(";")[0].strip()
        # Parse "numpy (>=1.20)" or "numpy>=1.20" or "numpy"
        m = re.match(r"^([\w.-]+)\s*(?:\(([^)]+)\)|(>=|==|!=|<=|>|<)([\w.*]+))?\s*$", entry)
        if m:
            name = m.group(1)
            spec = m.group(2) or ""
            deps.append((name, spec))
    return deps


# ── Package classification ────────────────────────────────────────────

RECIPES_PATH = SCRIPT_DIR / "recipes.json"


def load_recipes():
    if RECIPES_PATH.exists():
        return json.loads(RECIPES_PATH.read_text())
    return {}


def has_c_extensions(package_name):
    """Check if a package is known to have C extensions."""
    recipes = load_recipes()
    return package_name.lower() in recipes


def build_method(package_name):
    """Return 'meson', 'setuptools', or None (pure Python)."""
    recipes = load_recipes()
    info = recipes.get(package_name.lower())
    if info:
        return info.get("build", "setuptools")
    return None


def detect_build_system_from_sdist(src_dir):
    """Inspect an extracted sdist to determine the build system.
    
    Returns 'meson', 'setuptools', or None (pure Python / unknown).
    """
    src_dir = str(src_dir)
    has_meson_build = os.path.exists(os.path.join(src_dir, "meson.build"))
    has_setup_py = os.path.exists(os.path.join(src_dir, "setup.py"))
    has_setup_cfg = os.path.exists(os.path.join(src_dir, "setup.cfg"))

    # Check pyproject.toml for build-backend hint
    pyproject_path = os.path.join(src_dir, "pyproject.toml")
    build_backend = None
    if os.path.exists(pyproject_path):
        try:
            import tomllib
            with open(pyproject_path, "rb") as f:
                pyproject = tomllib.load(f)
            build_system = pyproject.get("build-system", {}) or {}
            build_backend = (build_system.get("build-backend") or "").lower()
        except Exception:
            pass

    if has_meson_build or "meson" in (build_backend or ""):
        return "meson"
    if has_setup_py or has_setup_cfg or "setuptools" in (build_backend or ""):
        return "setuptools"
    if build_backend:
        return "setuptools"  # unknown backend, try setuptools as fallback
    return None


def has_c_extensions_in_sdist(src_dir):
    """Check if an extracted sdist contains .c, .pyx, or .cpp files (C extensions)."""
    src_dir = str(src_dir)
    for root, dirs, files in os.walk(src_dir):
        # Skip common non-source dirs
        if "/." in root or "/__pycache__" in root:
            continue
        for f in files:
            if f.endswith((".c", ".pyx", ".cpp", ".cc")):
                return True
    return False


# ── Generate .pc file for iOS Python ──────────────────────────────────


def generate_pc_file(output_dir):
    """Create .pc files for the iOS Python installation."""
    os.makedirs(output_dir, exist_ok=True)

    # Headers are directly in ios/include/ (not ios/include/python3.13/)
    include_dir = str(IOS_INCLUDE_DIR)
    # Also add the subdirectory for cpython/ internal headers
    cpython_include = str(IOS_INCLUDE_DIR / "cpython")
    lib_dir = IOS_LIB_DIR

    content = textwrap.dedent(f"""\
    prefix={PROJECT_DIR}/ios
    exec_prefix=${{prefix}}
    libdir={lib_dir}
    includedir={include_dir}

    Name: Python
    Description: Python library
    Requires:
    Version: 3.13
    Libs.private:
    Libs:
    Cflags: -I${{includedir}} -I${{includedir}}/cpython
    """)
    # Create multiple names so Meson finds it regardless of query
    names = ["python3.pc", f"python-{IOS_PYTHON_VER}.pc", f"python{IOS_PYTHON_VER}.pc"]
    paths = []
    for name in names:
        path = os.path.join(output_dir, name)
        with open(path, "w") as f:
            f.write(content)
        paths.append(path)
    return paths[0]


# ── Generate Meson cross-file ─────────────────────────────────────────


def generate_meson_cross_file(output_dir):
    os.makedirs(output_dir, exist_ok=True)
    cross_path = os.path.join(output_dir, "meson-cross.ini")
    content = textwrap.dedent(f"""\
    [host_machine]
    system = 'darwin'
    cpu_family = 'aarch64'
    cpu = 'arm64'
    endian = 'little'

    [binaries]
    c = '{CC}'
    cpp = '{CXX}'
    ar = '{AR}'
    strip = '{shutil.which("strip") or "/usr/bin/strip"}'
    pkgconfig = '{shutil.which("pkg-config") or "/opt/homebrew/bin/pkg-config"}'

    [built-in options]
    c_args = ['-arch', '{ARCH}', '-isysroot', '{SDK_PATH}', '-miphoneos-version-min={MIN_IOS}']
    c_link_args = ['-arch', '{ARCH}', '-isysroot', '{SDK_PATH}', '-miphoneos-version-min={MIN_IOS}', '-Wl,-undefined,dynamic_lookup']
    cpp_args = ['-arch', '{ARCH}', '-isysroot', '{SDK_PATH}', '-miphoneos-version-min={MIN_IOS}']
    cpp_link_args = ['-arch', '{ARCH}', '-isysroot', '{SDK_PATH}', '-miphoneos-version-min={MIN_IOS}', '-Wl,-undefined,dynamic_lookup']
    """)
    with open(cross_path, "w") as f:
        f.write(content)
    return cross_path


# ── Pure Python install ───────────────────────────────────────────────


def install_pure_python(name, version, target_dir, verbose=False):
    """Install a pure-Python package via pip directly to site-packages."""
    spec = f"{name}=={version}" if version else name
    cmd = [
        sys.executable, "-m", "pip", "install",
        "--target", str(target_dir),
        "--no-deps",
        "--no-build-isolation",
        spec,
    ]
    if verbose:
        print(f"  pip install {spec} (pure Python)")
    try:
        subprocess.check_call(cmd, stdout=subprocess.DEVNULL if not verbose else None,
                              stderr=subprocess.STDOUT if not verbose else None)
        return True
    except subprocess.CalledProcessError as e:
        if verbose:
            print(f"  Failed: {e}")
        return False


# ── Meson cross-build ─────────────────────────────────────────────────


def build_meson_package(name, version, work_dir, verbose=False):
    """Cross-compile a Meson-based package for iOS."""
    spec = f"{name}=={version}" if version else name
    sdist_dir = os.path.join(work_dir, "sdist")

    os.makedirs(sdist_dir, exist_ok=True)

    # 1. Download sdist
    if verbose:
        print(f"  Downloading {spec} source...")
    subprocess.check_call([
        sys.executable, "-m", "pip", "download",
        "--no-binary", ":all:",
        "--dest", sdist_dir,
        "--no-deps",
        spec,
    ], stdout=subprocess.DEVNULL if not verbose else None,
       stderr=subprocess.STDOUT if not verbose else None)

    # 2. Extract
    extracted_dirs = []
    for fname in os.listdir(sdist_dir):
        fpath = os.path.join(sdist_dir, fname)
        if fname.endswith(".tar.gz"):
            subprocess.check_call(["tar", "xzf", fpath, "-C", sdist_dir])
            extracted_dir = os.path.join(sdist_dir, fname.replace(".tar.gz", ""))
            if os.path.isdir(extracted_dir):
                extracted_dirs.append(extracted_dir)
        elif fname.endswith(".zip"):
            with zipfile.ZipFile(fpath, "r") as zf:
                zf.extractall(sdist_dir)
            extracted_dir = os.path.join(sdist_dir, fname.replace(".zip", ""))
            if os.path.isdir(extracted_dir):
                extracted_dirs.append(extracted_dir)

    if not extracted_dirs:
        # Try removing version from name
        for fname in os.listdir(sdist_dir):
            fpath = os.path.join(sdist_dir, fname)
            if os.path.isdir(fpath) and fpath != sdist_dir:
                extracted_dirs.append(fpath)

    if not extracted_dirs:
        print(f"  ERROR: Could not extract sdist for {name}")
        return None

    src_dir = extracted_dirs[0]
    build_dir = os.path.join(work_dir, "build")
    install_dir = os.path.join(work_dir, "install")
    cross_dir = os.path.join(work_dir, "cross")

    # 3. Install build dependencies from pyproject.toml
    pyproject_path = os.path.join(src_dir, "pyproject.toml")
    if os.path.exists(pyproject_path):
        try:
            import tomllib
            with open(pyproject_path, "rb") as f:
                pyproject = tomllib.load(f)
            build_requires = (pyproject.get("build-system", {}) or {}).get("requires", [])
            if build_requires:
                if verbose:
                    print(f"  Installing build deps: {[r.split(';')[0].strip() for r in build_requires]}")
                subprocess.check_call(
                    [sys.executable, "-m", "pip", "install"] + build_requires,
                    stdout=subprocess.DEVNULL if not verbose else None,
                    stderr=subprocess.STDOUT if not verbose else None,
                )
        except Exception as e:
            if verbose:
                print(f"  WARNING: could not install build deps: {e}")

    # 4. Generate cross files
    pc_path = generate_pc_file(cross_dir)
    cross_path = generate_meson_cross_file(cross_dir)

    # 5. Find the meson command
    vendored_meson = os.path.join(src_dir, "vendored-meson", "meson", "meson.py")
    if os.path.exists(vendored_meson):
        meson_cmd = [sys.executable, vendored_meson]
    else:
        try:
            from mesonbuild.mesonmain import main
            meson_cmd = [sys.executable, "-m", "mesonbuild.mesonmain"]
        except ImportError:
            meson_cmd = ["meson"]  # fallback to PATH

    # 5. Meson setup
    env = os.environ.copy()

    # Add the current Python's bin dir to PATH (for cython etc.)
    python_bin = os.path.dirname(sys.executable)
    path_parts = env.get("PATH", "").split(":")
    if python_bin not in path_parts:
        env["PATH"] = f"{python_bin}:{env.get('PATH', '')}"

    env["PKG_CONFIG_LIBDIR"] = cross_dir  # override default, ONLY search our .pc file
    env["PKG_CONFIG_PATH"] = ""  # explicit empty
    env["CC"] = CC
    env["CXX"] = CXX
    env["CFLAGS"] = CFLAGS
    env["LDFLAGS"] = f"{LDFLAGS} -Wl,-undefined,dynamic_lookup"
    env["AR"] = AR

    if verbose:
        print(f"  meson setup (cross-compile for iOS arm64)...")
    setup_cmd = meson_cmd + ["setup", build_dir, "--cross-file", cross_path]
    if os.path.exists(os.path.join(src_dir, "meson.build")):
        setup_cmd += ["-Dpython.platlibdir=lib/python3.13/site-packages"]
    try:
        subprocess.check_call(setup_cmd, cwd=src_dir, env=env)
    except subprocess.CalledProcessError:
        # Try without platlibdir
        try:
            subprocess.check_call(meson_cmd + ["setup", build_dir, "--cross-file", cross_path],
                                  cwd=src_dir, env=env)
        except subprocess.CalledProcessError as e:
            print(f"  ERROR: meson setup failed for {name}")
            return None

    # 6. Meson compile
    if verbose:
        print(f"  meson compile...")
    try:
        subprocess.check_call(meson_cmd + ["compile", "-C", build_dir],
                              cwd=src_dir, env=env)
    except subprocess.CalledProcessError as e:
        print(f"  ERROR: meson compile failed for {name}")
        return None

    # 7. Meson install
    if verbose:
        print(f"  meson install...")
    os.makedirs(install_dir, exist_ok=True)
    try:
        subprocess.check_call(meson_cmd + ["install", "-C", build_dir, "--destdir", install_dir],
                              cwd=src_dir, env=env)
    except subprocess.CalledProcessError as e:
        print(f"  ERROR: meson install failed for {name}")
        return None

    # 8. Find installed package dir
    installed = find_installed_package(install_dir, name)
    return installed


def find_installed_package(install_dir, pkg_name):
    """Find the installed package directory under install_dir."""
    # Meson installs to $DESTDIR/prefix/...
    # Look for site-packages/<pkg_name>/
    for root, dirs, files in os.walk(install_dir):
        if os.path.basename(root) == pkg_name:
            # Check if this is actually a Python package
            if any(f.endswith(".py") for f in files):
                return root
        # Also check for single .py files at top level
    # Try broader search
    for root, dirs, files in os.walk(install_dir):
        for d in dirs:
            if d == pkg_name:
                pkg_dir = os.path.join(root, d)
                if any(f.endswith((".py", ".so")) for f in os.listdir(pkg_dir)):
                    return pkg_dir
        for f in files:
            if f == f"{pkg_name}.py":
                return root
    return None


# ── Setuptools cross-build ────────────────────────────────────────────


def build_setuptools_package(name, version, work_dir, verbose=False):
    """Cross-compile a setuptools-based package for iOS."""
    spec = f"{name}=={version}" if version else name
    sdist_dir = os.path.join(work_dir, "sdist")
    os.makedirs(sdist_dir, exist_ok=True)

    # 1. Download sdist
    if verbose:
        print(f"  Downloading {spec} source...")
    subprocess.check_call([
        sys.executable, "-m", "pip", "download",
        "--no-binary", ":all:",
        "--dest", sdist_dir,
        "--no-deps",
        spec,
    ], stdout=subprocess.DEVNULL if not verbose else None,
       stderr=subprocess.STDOUT if not verbose else None)

    # 2. Extract
    extracted_dirs = []
    for fname in os.listdir(sdist_dir):
        fpath = os.path.join(sdist_dir, fname)
        if fname.endswith(".tar.gz"):
            subprocess.check_call(["tar", "xzf", fpath, "-C", sdist_dir])
            extracted_dirs.append(os.path.join(sdist_dir, fname.replace(".tar.gz", "")))
        elif fname.endswith(".zip"):
            with zipfile.ZipFile(fpath, "r") as zf:
                zf.extractall(sdist_dir)
            extracted_dirs.append(os.path.join(sdist_dir, fname.replace(".zip", "")))

    if not extracted_dirs:
        for fname in os.listdir(sdist_dir):
            fpath = os.path.join(sdist_dir, fname)
            if os.path.isdir(fpath) and fpath != sdist_dir:
                extracted_dirs.append(fpath)

    if not extracted_dirs:
        print(f"  ERROR: Could not extract sdist for {name}")
        return None

    src_dir = extracted_dirs[0]
    install_dir = os.path.join(work_dir, "install")
    os.makedirs(install_dir, exist_ok=True)

    # 3. Cross-compile with setuptools
    env = os.environ.copy()
    env["CC"] = CC
    env["CXX"] = CXX
    env["CFLAGS"] = CFLAGS
    env["LDFLAGS"] = f"{LDFLAGS} -Wl,-undefined,dynamic_lookup"
    env["AR"] = AR
    env["_PYTHON_HOST_PLATFORM"] = "ios"
    env["ARCHFLAGS"] = f"-arch {ARCH}"

    include_flag = f"-I{IOS_INCLUDE_DIR}/python{IOS_PYTHON_VER}"

    if verbose:
        print(f"  python setup.py build_ext for iOS...")

    try:
        # Build extensions
        subprocess.check_call([
            sys.executable, "setup.py", "build_ext",
            f"--include-dirs={IOS_INCLUDE_DIR}/python{IOS_PYTHON_VER}",
            f"--library-dirs={IOS_LIB_DIR}",
            "--plat-name=ios",
        ], cwd=src_dir, env=env,
           stdout=subprocess.DEVNULL if not verbose else None,
           stderr=subprocess.STDOUT if not verbose else None)

        # Install
        subprocess.check_call([
            sys.executable, "setup.py", "install",
            f"--prefix={install_dir}",
            "--single-version-externally-managed",
            "--record=/dev/null",
        ], cwd=src_dir, env=env,
           stdout=subprocess.DEVNULL if not verbose else None,
           stderr=subprocess.STDOUT if not verbose else None)
    except subprocess.CalledProcessError as e:
        print(f"  ERROR: build failed for {name}")
        return None

    # 4. Find installed package
    installed = find_installed_package(install_dir, name)
    return installed


# ── Install package to iOS project ────────────────────────────────────


def install_to_project(pkg_dir, pkg_name, verbose=False):
    """Copy a built package into the iOS site-packages directory."""
    target = IOS_SITE_PACKAGES / pkg_name
    if target.exists():
        if verbose:
            print(f"  Removing existing {target}")
        shutil.rmtree(target)

    if verbose:
        print(f"  Installing to {target}")
    shutil.copytree(pkg_dir, target, symlinks=False)
    return target


def post_process_so_files(pkg_dir, verbose=False):
    """Rename .so files from *-darwin.so to *.so and remove Python.framework refs."""
    for root, dirs, files in os.walk(pkg_dir):
        for fname in files:
            fpath = os.path.join(root, fname)
            # Rename: strip -darwin from SOABI
            if "-darwin" in fname and fname.endswith(".so"):
                new_name = fname.replace("-darwin", "")
                new_path = os.path.join(root, new_name)
                os.rename(fpath, new_path)
                if verbose:
                    print(f"  Renamed {fname} → {new_name}")
                fpath = new_path

            # Remove @rpath/Python.framework/Python dependency
            if fpath.endswith(".so"):
                try:
                    result = subprocess.run(
                        ["otool", "-L", fpath], capture_output=True, text=True, check=True
                    )
                    if "@rpath/Python.framework/Python" in result.stdout:
                        subprocess.check_call([
                            "install_name_tool", "-change",
                            "@rpath/Python.framework/Python",
                            "@rpath/RNPythonBridge.debug.dylib",
                            fpath,
                        ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                        if verbose:
                            print(f"  Patched @rpath in {os.path.basename(fpath)}")
                except subprocess.CalledProcessError:
                    pass  # not a Mach-O file, skip


# ── Dependency resolution ─────────────────────────────────────────────


def resolve_deps(package_name, version, seen=None, verbose=False, force=False, upgrade=False):
    """Recursively resolve dependencies. Returns list of (name, version, method)."""
    if seen is None:
        seen = set()

    result = []
    if package_name.lower() in seen:
        return result
    seen.add(package_name.lower())

    # Check if already installed (skip unless force or upgrade)
    pkg_dir = IOS_SITE_PACKAGES / package_name
    if pkg_dir.exists() and not force and not upgrade:
        if verbose:
            print(f"  {package_name}: already installed, skipping")
        return result

    try:
        data = pypi_json(package_name)
    except Exception as e:
        print(f"  WARNING: could not fetch PyPI info for {package_name}: {e}")
        return result

    info = data["info"]
    latest = info["version"]
    ver = version or latest

    # Get deps
    deps = get_requires_dist(data, ver)

    # Install deps first
    for dep_name, dep_spec in deps:
        sub_result = resolve_deps(dep_name, None, seen, verbose, force, upgrade)
        result.extend(sub_result)

    # Determine build method
    if has_c_extensions(package_name):
        method = build_method(package_name)
    else:
        method = "pure"

    result.append((package_name, ver, method))
    return result


# ── CLI ────────────────────────────────────────────────────────────────


def _download_and_extract_sdist(name, version, dest_dir, verbose=False):
    """Download and extract an sdist. Returns the extracted source dir or None."""
    spec = f"{name}=={version}" if version else name
    os.makedirs(dest_dir, exist_ok=True)
    try:
        if verbose:
            print(f"  Downloading {spec} source...")
        subprocess.check_call([
            sys.executable, "-m", "pip", "download",
            "--no-binary", ":all:",
            "--dest", dest_dir,
            "--no-deps",
            spec,
        ], stdout=subprocess.DEVNULL if not verbose else None,
           stderr=subprocess.STDOUT if not verbose else None)
    except subprocess.CalledProcessError:
        return None

    extracted = None
    for fname in os.listdir(dest_dir):
        fpath = os.path.join(dest_dir, fname)
        if fname.endswith(".tar.gz"):
            subprocess.check_call(["tar", "xzf", fpath, "-C", dest_dir])
            extracted = os.path.join(dest_dir, fname.replace(".tar.gz", ""))
            if os.path.isdir(extracted):
                break
        elif fname.endswith(".zip"):
            with zipfile.ZipFile(fpath, "r") as zf:
                zf.extractall(dest_dir)
            extracted = os.path.join(dest_dir, fname.replace(".zip", ""))
            if os.path.isdir(extracted):
                break

    if not extracted or not os.path.isdir(extracted):
        # Try without version suffix
        for fname in os.listdir(dest_dir):
            fpath = os.path.join(dest_dir, fname)
            if os.path.isdir(fpath) and fpath != dest_dir:
                extracted = fpath
                break
    return extracted


def _auto_detect_method(name, version, work_dir, verbose=False):
    """Download sdist and auto-detect build method for an unknown package.
    
    Returns ('meson', src_dir), ('setuptools', src_dir), or (None, None).
    """
    sdist_dir = os.path.join(work_dir, "sdist")
    if os.path.exists(sdist_dir):
        shutil.rmtree(sdist_dir)
    src_dir = _download_and_extract_sdist(name, version, sdist_dir, verbose)
    if not src_dir:
        return None, None

    has_c = has_c_extensions_in_sdist(src_dir)
    if not has_c:
        if verbose:
            print(f"  No C extensions found in sdist for {name}")
        return None, src_dir  # pure Python, let caller decide

    method = detect_build_system_from_sdist(src_dir)
    if method:
        if verbose:
            print(f"  Detected build system: {method}")
        return method, src_dir

    if verbose:
        print(f"  Could not detect build system for {name}, falling back to setuptools")
    return "setuptools", src_dir


def cmd_install(args):
    force = args.force_reinstall or args.upgrade
    dry_run = args.dry_run

    packages = []
    if args.requirements:
        with open(args.requirements) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#"):
                    packages.append(line)
    if args.package:
        packages.append(args.package)

    for spec in packages:
        # Parse "package==version" or "package"
        m = re.match(r"([\w.-]+)(?:[=]=([\w.*]+))?", spec)
        if not m:
            print(f"ERROR: invalid package spec: {spec}")
            continue
        pkg_name, pkg_ver = m.group(1), m.group(2)

        if dry_run:
            print(f"\n=== Would resolve {pkg_name} ===")
        else:
            print(f"\n=== Resolving {pkg_name} ===")

        # Resolve dependencies
        dep_chain = resolve_deps(pkg_name, pkg_ver, verbose=args.verbose,
                                 force=force, upgrade=args.upgrade)
        if not dep_chain:
            print(f"  (nothing to install)")
            continue

        # Ensure numpy is built before anything that depends on it
        # Sort: non-meson first, then meson, then the target package
        dep_chain.sort(key=lambda x: (x[2] != "pure", x[0] == pkg_name))

        if dry_run:
            print("  Would install:")
            for dep_name, dep_ver, method in dep_chain:
                label = f"{dep_name}=={dep_ver}"
                if method == "meson":
                    print(f"    ⏬ {label} (cross-compile with Meson)")
                elif method == "setuptools":
                    print(f"    ⏬ {label} (cross-compile with setuptools)")
                else:
                    print(f"    📦 {label} (pip install)")
            continue

        for dep_name, dep_ver, method in dep_chain:
            if dep_name == pkg_name:
                print(f"\n*** Installing {dep_name}=={dep_ver} (target) ***")
            else:
                print(f"\n  Installing dependency: {dep_name}=={dep_ver}")

            # --- Pure Python install ---
            if method == "pure":
                ok = install_pure_python(dep_name, dep_ver, IOS_SITE_PACKAGES, args.verbose)
                if ok:
                    print(f"  ✓ {dep_name}=={dep_ver} installed (pure Python)")
                    continue
                # Pure pip failed → try to detect build system and cross-build
                print(f"  ✗ {dep_name}=={dep_ver} pure install failed, checking for C extensions...")
                work_dir = f"/tmp/cross-build-{dep_name}"
                os.makedirs(work_dir, exist_ok=True)
                detected_method, src_dir = _auto_detect_method(dep_name, dep_ver, work_dir, args.verbose)
                if detected_method:
                    method = detected_method
                    print(f"  → detected {method}, cross-compiling...")
                elif src_dir:
                    # Has no C extensions but pip failed anyway — report error
                    print(f"  ✗ {dep_name}=={dep_ver} install FAILED (no C extensions found, pip error)")
                    continue
                else:
                    # Could not even download sdist
                    print(f"  ✗ {dep_name}=={dep_ver} install FAILED (could not download source)")
                    continue

            # --- Cross-compile (Meson or setuptools) ---
            if method in ("meson", "setuptools"):
                if method == "meson":
                    builder = build_meson_package
                else:
                    builder = build_setuptools_package

                work_dir = f"/tmp/cross-build-{dep_name}"
                os.makedirs(work_dir, exist_ok=True)
                pkg_dir = builder(dep_name, dep_ver, work_dir, args.verbose)
                if pkg_dir:
                    installed = install_to_project(pkg_dir, dep_name, args.verbose)
                    post_process_so_files(installed, args.verbose)
                    so_count = len(list(Path(installed).rglob("*.so")))
                    print(f"  ✓ {dep_name}=={dep_ver} installed ({so_count} .so files)")
                else:
                    print(f"  ✗ {dep_name}=={dep_ver} build FAILED")
                    print(f"    Build directory preserved at {work_dir}")

        print(f"\n✓ {pkg_name} and all dependencies installed")


def cmd_list(args):
    if not IOS_SITE_PACKAGES.exists():
        print("No packages installed.")
        return
    packages = sorted([
        d.name for d in IOS_SITE_PACKAGES.iterdir()
        if d.is_dir() and (d / "__init__.py").exists()
    ])
    if not packages:
        print("No packages installed.")
        return
    print("Installed packages:")
    for pkg in packages:
        # Check for .so files
        so_count = len(list((IOS_SITE_PACKAGES / pkg).rglob("*.so")))
        has_c = " (C extensions)" if so_count > 0 else ""
        print(f"  {pkg}{has_c}")


def cmd_info(args):
    pkg = args.package
    if has_c_extensions(pkg):
        method = build_method(pkg)
        print(f"{pkg}: C-extension package (build: {method})")
    else:
        print(f"{pkg}: pure Python (pip install)")
    try:
        data = pypi_json(pkg)
        info = data["info"]
        print(f"  Latest version: {info['version']}")
        deps = get_requires_dist(data, info["version"])
        if deps:
            print(f"  Dependencies:")
            for d_name, d_spec in deps:
                print(f"    - {d_name} {d_spec}")
    except Exception as e:
        print(f"  (could not fetch PyPI info: {e})")


def main():
    parser = argparse.ArgumentParser(
        description="cross-pip: cross-compile Python packages for iOS",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Examples:
              cross-pip install numpy
              cross-pip install pandas==2.2.3
              cross-pip install -v scipy --dry-run
              cross-pip install -r requirements.txt --force-reinstall
              cross-pip list
              cross-pip info requests
        """),
    )
    parser.add_argument("--verbose", "-v", action="store_true", help="verbose output")
    parser.add_argument("--version", action="store_true", help="show version and exit")

    sub = parser.add_subparsers(dest="command")

    install_parser = sub.add_parser("install", help="install a package")
    install_parser.add_argument("package", nargs="?", help="package name (e.g. pandas or pandas==2.2.3)")
    install_parser.add_argument("-r", "--requirements", help="requirements file")
    install_parser.add_argument("--force-reinstall", "-f", action="store_true",
                                help="reinstall even if already installed")
    install_parser.add_argument("--upgrade", "-U", action="store_true",
                                help="upgrade to latest version (implies --force-reinstall)")
    install_parser.add_argument("--dry-run", "-n", action="store_true",
                                help="show what would be installed without doing it")

    list_parser = sub.add_parser("list", help="list installed packages")
    info_parser = sub.add_parser("info", help="show package info")
    info_parser.add_argument("package", help="package name")

    args = parser.parse_args()

    if args.version:
        print(f"cross-pip version {VERSION}")
        return

    if args.command == "install":
        if not args.package and not args.requirements:
            install_parser.error("specify a package or -r")
        cmd_install(args)
    elif args.command == "list":
        cmd_list(args)
    elif args.command == "info":
        cmd_info(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
