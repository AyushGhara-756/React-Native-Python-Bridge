#!/usr/bin/env python3
"""
cross-pip — cross-compile Python packages for iOS.

Usage:
  cross-pip install <package>        latest version
  cross-pip install <package>==X.Y   specific version
  cross-pip install -r deps.txt      batch install
  cross-pip list                     show installed packages
  cross-pip info <package>           show how a package would be built
"""
